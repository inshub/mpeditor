{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mpeditor",
  "mainBinaryName": "mpeditor",
  "version": "1.0.2",
  "identifier": "cn.inshub.mp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBKEY__",
      "endpoints": ["__TAURI_UPDATER_ENDPOINT__"],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "微信公众号编辑助手",
        "width": 1460,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        },
        "center": true,
        "shadow": true,
        "visible": false,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "dmg"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
